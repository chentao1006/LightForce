{
  "manifest_version": 3,
  "name": "Light Force",
  "version": "1.0",
  "description": "May the Light Force be with you. Forces dark-themed websites into light mode, leaving originally light websites unaffected.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon-128.png",
      "48": "icon-48.png",
      "16": "icon-16.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "icons": {
    "128": "icon-128.png",
    "48": "icon-48.png",
    "16": "icon-16.png"
  }
}